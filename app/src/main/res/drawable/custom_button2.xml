<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFB6C1" /> <!-- Lighter pink when pressed -->
        </shape>
    </item>
    <item> <!-- Default state -->
        <shape android:shape="rectangle">
            <solid android:color="#FF69B4" /> <!-- Hot Pink for normal state -->
        </shape>
    </item>
</selector>